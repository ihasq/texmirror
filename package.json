{
  "name": "texmirror",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "verify:e2e": "node scripts/verify-e2e.mjs",
    "update:pdfjs": "node scripts/update-pdfjs.mjs",
    "download:busytex": "texlyre-busytex download-assets .cache/busytex/raw-root && node scripts/patch-busytex-assets.mjs .cache/busytex/raw-root/busytex"
  },
  "dependencies": {
    "idb-keyval": "^6.3.0",
    "lucide-preact": "^1.23.0",
    "monaco-editor": "^0.53.0",
    "preact": "^10.29.7",
    "texlyre-busytex": "^1.2.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "playwright-core": "^1.61.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.3"
  }
}
